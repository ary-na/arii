---
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: import('astro').ImageMetadata;
  canonicalPath?: string;
  contentClass?: string;
  schema?: Record<string, unknown>;
}

const { title, description, image, canonicalPath, contentClass, schema } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {title} {description} {image} {canonicalPath} {schema} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main
      id="main-content"
      class:list={['flex flex-1 flex-col justify-center', contentClass]}
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
