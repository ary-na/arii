---
import { getCollection } from "astro:content";
import { categoryHref, SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";

const posts = await getCollection("blog");
const categories = [
  ...new Set(posts.flatMap((post) => post.data.category ?? [])),
];
---

<header>
  <!-- Mobile (<md): fullscreen overlay -->
  <div class="md:hidden fixed top-0 right-0 z-50 p-6">
    <button
      id="mobile-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="group relative flex h-11 w-11 items-center justify-center rounded-full border border-[rgba(0,0,0,0.08)] bg-white/72 shadow-[0_10px_24px_rgba(15,23,42,0.08)] backdrop-blur-md transition hover:bg-white dark:border-[rgba(255,255,255,0.12)] dark:bg-[rgba(255,255,255,0.08)] dark:hover:bg-[rgba(255,255,255,0.12)]"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <span
        class="mobile-line mobile-line--top absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
      <span
        class="mobile-line mobile-line--middle absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-200 ease-out"
      ></span>
      <span
        class="mobile-line mobile-line--bottom absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
    </button>
  </div>

  <!-- Mobile fullscreen menu -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 z-40 flex flex-col items-start justify-center gap-8 bg-secondary ps-10"
  >
    <h2 class="text-2xl font-bold tracking-wider border-b border-primary pb-2 w-full">
      <a href="/">{SITE_TITLE}</a>
    </h2>
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/blog">Blog</HeaderLink>
    <HeaderLink href="/about">About</HeaderLink>
    <span class="font-display tracking-widest border-b border-primary w-full">
      categories
    </span>
    {
      categories.map((category) => (
        <HeaderLink href={categoryHref(category)}>{category}</HeaderLink>
      ))
    }
  </div>

  <!-- Tablet (md to xl): right side panel -->
  <div class="hidden md:block xl:hidden fixed top-0 right-0 z-50 p-6">
    <button
      id="tablet-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="group relative flex h-11 w-11 items-center justify-center rounded-full border border-[rgba(0,0,0,0.08)] bg-white/72 shadow-[0_10px_24px_rgba(15,23,42,0.08)] backdrop-blur-md transition hover:bg-white dark:border-[rgba(255,255,255,0.12)] dark:bg-[rgba(255,255,255,0.08)] dark:hover:bg-[rgba(255,255,255,0.12)]"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <span
        class="tablet-line tablet-line--top absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
      <span
        class="tablet-line tablet-line--middle absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-200 ease-out"
      ></span>
      <span
        class="tablet-line tablet-line--bottom absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
    </button>
  </div>

  <!-- Tablet slide-in panel -->
  <div
    id="tablet-menu"
    class="hidden md:flex xl:hidden fixed top-0 right-0 h-full z-40 flex-col items-start justify-center gap-6 px-8 w-70 bg-secondary"
  >
    <h2 class="text-lg font-bold tracking-wider border-b border-primary pb-2 w-full">
      <a href="/">{SITE_TITLE}</a>
    </h2>
    <HeaderLink href="/">Home</HeaderLink>
    <HeaderLink href="/blog">Blog</HeaderLink>
    <HeaderLink href="/about">About</HeaderLink>
    <span class="text-xs font-semibold uppercase tracking-widest">
      Categories
    </span>
    {
      categories.map((category) => (
        <HeaderLink href={categoryHref(category)}>{category}</HeaderLink>
      ))
    }
  </div>

  <!-- Desktop (xl+): right sidebar unchanged -->
  <nav
    class="hidden xl:fixed xl:right-0 xl:top-0 xl:h-full xl:flex xl:flex-col xl:gap-6 xl:items-start xl:justify-center xl:w-68"
  >
    <span class="text-3xl w-100 font-display font-bold tracking-tight pb-2 border-b border-secondary">
      <a href="/">{SITE_TITLE}</a>
    </span>
    <div class="flex flex-col gap-2 w-100">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="flex flex-col gap-1 w-100">
      <span class="font-display border-b border-secondary mb-2">
        categories
      </span>
      <div class="italic text-sm">
        {
          categories.map((category) => (
            <HeaderLink href={categoryHref(category)}>{category}</HeaderLink>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<style>
  #mobile-toggle,
  #tablet-toggle {
    color: var(--text-primary);
  }

  .mobile-line,
  .tablet-line {
    left: 50%;
    top: 50%;
    transform-origin: center;
    translate: -50% -50%;
  }

  .mobile-line--top,
  .tablet-line--top {
    transform: translateY(-6px);
  }

  .mobile-line--middle,
  .tablet-line--middle {
    transform: translateY(0);
  }

  .mobile-line--bottom,
  .tablet-line--bottom {
    transform: translateY(6px);
  }

  /* Mobile fullscreen */
  #mobile-menu {
    opacity: 0;
    pointer-events: none;
    transform: translateX(100%);
    transition:
      transform 300ms ease,
      opacity 300ms ease;
  }

  #mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(0);
  }

  #mobile-toggle.is-open .mobile-line--top {
    transform: rotate(45deg);
  }

  #mobile-toggle.is-open .mobile-line--middle {
    transform: scaleX(0.35);
    opacity: 0;
  }

  #mobile-toggle.is-open .mobile-line--bottom {
    transform: rotate(-45deg);
  }

  /* Tablet slide-in */
  #tablet-menu {
    transform: translateX(100%);
    transition: transform 300ms ease;
  }

  #tablet-menu.is-open {
    transform: translateX(0);
  }

  #tablet-toggle.is-open .tablet-line--top {
    transform: rotate(45deg);
  }

  #tablet-toggle.is-open .tablet-line--middle {
    transform: scaleX(0.35);
    opacity: 0;
  }

  #tablet-toggle.is-open .tablet-line--bottom {
    transform: rotate(-45deg);
  }
</style>

<script>
  // Mobile
  const mobileToggle = document.getElementById(
    "mobile-toggle",
  ) as HTMLButtonElement;
  const mobileMenu = document.getElementById("mobile-menu") as HTMLElement;
  mobileToggle?.addEventListener("click", () => {
    const isOpen = mobileMenu.classList.contains("is-open");

    if (isOpen) {
      mobileMenu.classList.remove("is-open");
      mobileToggle.classList.remove("is-open");
      mobileToggle.setAttribute("aria-expanded", "false");
    } else {
      mobileMenu.classList.add("is-open");
      mobileToggle.classList.add("is-open");
      mobileToggle.setAttribute("aria-expanded", "true");
    }
  });

  // Tablet
  const tabletToggle = document.getElementById(
    "tablet-toggle",
  ) as HTMLButtonElement;
  const tabletMenu = document.getElementById("tablet-menu") as HTMLElement;
  tabletToggle?.addEventListener("click", () => {
    const isOpen = tabletMenu.classList.contains("is-open");

    if (isOpen) {
      tabletMenu.classList.remove("is-open");
      tabletToggle.classList.remove("is-open");
      tabletToggle.setAttribute("aria-expanded", "false");
    } else {
      tabletMenu.classList.add("is-open");
      tabletToggle.classList.add("is-open");
      tabletToggle.setAttribute("aria-expanded", "true");
    }
  });
</script>
