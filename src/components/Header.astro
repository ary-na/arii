---
import { getCollection } from 'astro:content';
import { categoryHref, SITE_TITLE, PRIMARY_NAV } from '@/consts';
import HeaderLink from './HeaderLink.astro';

const posts = await getCollection('blog');
const categories = [...new Set(posts.flatMap((post) => post.data.category ?? []))];
---

<header class="text-text-primary">
  <!-- Mobile (<md): fullscreen overlay -->
  <div class="fixed top-0 right-0 z-50 p-6 md:hidden">
    <button
      id="mobile-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="group cursor-pointer border-text-secondary/20 bg-surface-primary/85 text-text-primary hover:bg-surface-primary relative flex h-11 w-11 items-center justify-center rounded-full border shadow-(--box-shadow) backdrop-blur-md transition"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <span
        class="mobile-line mobile-line--top absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
      <span
        class="mobile-line mobile-line--middle absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-200 ease-out"
      ></span>
      <span
        class="mobile-line mobile-line--bottom absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
    </button>
  </div>

  <!-- Mobile fullscreen menu -->
  <div
    id="mobile-menu"
    class="bg-surface-primary text-text-primary fixed inset-0 z-40 flex flex-col items-start justify-center gap-6 ps-10 md:hidden"
  >
    <span class="font-display border-primary w-200 border-b pb-2 text-3xl font-bold tracking-tight">
      <a href="/">{SITE_TITLE}</a>
    </span>
    <div class="flex w-100 flex-col gap-2">
      {
        PRIMARY_NAV.map((item) => (
          <HeaderLink href={item.href} description={item.description}>
            {item.label}
          </HeaderLink>
        ))
      }
    </div>
    <div class="flex w-200 flex-col gap-1">
      <span class="font-display border-primary mb-2 border-b"> categories </span>
      <div class="text-text-secondary text-sm italic">
        {
          categories.map((category) => (
            <HeaderLink href={categoryHref(category)}>{category}</HeaderLink>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Tablet (md to xl): right side panel -->
  <div class="fixed top-0 right-0 z-50 hidden p-6 md:block xl:hidden">
    <button
      id="tablet-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="group cursor-pointer border-text-secondary/20 bg-surface-primary/85 text-text-primary hover:bg-surface-primary relative flex h-11 w-11 items-center justify-center rounded-full border shadow-(--box-shadow) backdrop-blur-md transition"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <span
        class="tablet-line tablet-line--top absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
      <span
        class="tablet-line tablet-line--middle absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-200 ease-out"
      ></span>
      <span
        class="tablet-line tablet-line--bottom absolute block h-0.5 w-5 rounded-full bg-current transition-all duration-300 ease-out"
      ></span>
    </button>
  </div>

  <!-- Tablet slide-in panel -->
  <div
    id="tablet-menu"
    class="bg-surface-primary border-text-secondary/15 text-text-primary fixed top-0 right-0 z-40 hidden h-full w-68 flex-col items-start justify-center gap-6 border-l px-8 shadow-(--box-shadow) md:flex xl:hidden"
  >
    <span class="font-display border-primary w-100 border-b pb-2 text-3xl font-bold tracking-tight">
      <a href="/">{SITE_TITLE}</a>
    </span>
    <div class="flex w-100 flex-col gap-2">
      {
        PRIMARY_NAV.map((item) => (
          <HeaderLink href={item.href} description={item.description}>
            {item.label}
          </HeaderLink>
        ))
      }
    </div>
    <div class="flex w-100 flex-col gap-1">
      <span class="font-display border-primary mb-2 border-b"> categories </span>
      <div class="text-text-secondary text-sm italic">
        {
          categories.map((category) => (
            <HeaderLink href={categoryHref(category)}>{category}</HeaderLink>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Desktop (xl+): right sidebar unchanged -->
  <nav
    class="xl:bg-surface-primary/35 hidden xl:fixed xl:top-0 xl:right-0 xl:flex xl:h-full xl:w-68 xl:flex-col xl:items-start xl:justify-center xl:gap-6 xl:px-8 xl:backdrop-blur-sm"
  >
    <span class="font-display border-primary w-100 border-b pb-2 text-3xl font-bold tracking-tight">
      <a href="/">{SITE_TITLE}</a>
    </span>
    <div class="flex w-100 flex-col gap-2">
      {
        PRIMARY_NAV.map((item) => (
          <HeaderLink href={item.href} description={item.description}>
            {item.label}
          </HeaderLink>
        ))
      }
    </div>
    <div class="flex w-100 flex-col gap-1">
      <span class="font-display border-primary mb-2 border-b"> categories </span>
      <div class="text-text-secondary text-sm italic">
        {
          categories.map((category) => (
            <HeaderLink href={categoryHref(category)}>{category}</HeaderLink>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<style>
  #mobile-toggle,
  #tablet-toggle {
    color: var(--text-primary);
  }

  .mobile-line,
  .tablet-line {
    left: 50%;
    top: 50%;
    transform-origin: center;
    translate: -50% -50%;
  }

  .mobile-line--top,
  .tablet-line--top {
    transform: translateY(-6px);
  }

  .mobile-line--middle,
  .tablet-line--middle {
    transform: translateY(0);
  }

  .mobile-line--bottom,
  .tablet-line--bottom {
    transform: translateY(6px);
  }

  /* Mobile fullscreen */
  #mobile-menu {
    opacity: 0;
    pointer-events: none;
    transform: translateX(100%);
    transition:
      transform 300ms ease,
      opacity 300ms ease;
  }

  #mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(0);
  }

  #mobile-toggle.is-open .mobile-line--top {
    transform: rotate(45deg);
  }

  #mobile-toggle.is-open .mobile-line--middle {
    transform: scaleX(0.35);
    opacity: 0;
  }

  #mobile-toggle.is-open .mobile-line--bottom {
    transform: rotate(-45deg);
  }

  /* Tablet slide-in */
  #tablet-menu {
    transform: translateX(100%);
    transition: transform 300ms ease;
  }

  #tablet-menu.is-open {
    transform: translateX(0);
  }

  #tablet-toggle.is-open .tablet-line--top {
    transform: rotate(45deg);
  }

  #tablet-toggle.is-open .tablet-line--middle {
    transform: scaleX(0.35);
    opacity: 0;
  }

  #tablet-toggle.is-open .tablet-line--bottom {
    transform: rotate(-45deg);
  }
</style>

<script>
  const bindMenuToggle = (toggleId: string, menuId: string) => {
    const toggle = document.getElementById(toggleId) as HTMLButtonElement | null;
    const menu = document.getElementById(menuId) as HTMLElement | null;

    if (!toggle || !menu || toggle.dataset.bound === 'true') return;

    toggle.dataset.bound = 'true';
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('is-open');

      if (isOpen) {
        menu.classList.remove('is-open');
        toggle.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        menu.classList.add('is-open');
        toggle.classList.add('is-open');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  };

  const initHeaderMenus = () => {
    bindMenuToggle('mobile-toggle', 'mobile-menu');
    bindMenuToggle('tablet-toggle', 'tablet-menu');
  };

  document.addEventListener('astro:page-load', initHeaderMenus);
  initHeaderMenus();
</script>
