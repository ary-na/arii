---
const {
  demo,
  github,
  githubBackend,
  trello,
  demoCrossed,
  demoLabel = 'live demo',
  githubLabel = 'github',
  githubBackendLabel = 'github backend',
  trelloLabel = 'trello',
} = Astro.props;
---
<div class="my-4 flex flex-wrap gap-2 font-mono text-sm sm:gap-4">
  {
    demo && (
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="group text-text-secondary hover:text-text-primary no-underline transition-colors duration-200"
      >
        <span class="text-accent">[</span>
        <span class:list={[{ 'line-through': demoCrossed }]}>{demoLabel}</span>
        <span class="text-accent">]</span>
      </a>
    )
  }
  {
    github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="group text-text-secondary hover:text-text-primary no-underline transition-colors duration-200"
      >
        <span class="text-accent">[</span>
        <span>{githubLabel}</span>
        <span class="text-accent">]</span>
      </a>
    )
  }
  {
    githubBackend && (
      <a
        href={githubBackend}
        target="_blank"
        rel="noopener noreferrer"
        class="group text-text-secondary hover:text-text-primary no-underline transition-colors duration-200"
      >
        <span class="text-accent">[</span>
        <span>{githubBackendLabel}</span>
        <span class="text-accent">]</span>
      </a>
    )
  }
  {
    trello && (
      <a
        href={trello}
        target="_blank"
        rel="noopener noreferrer"
        class="group text-text-secondary hover:text-text-primary no-underline transition-colors duration-200"
      >
        <span class="text-accent">[</span>
        <span>{trelloLabel}</span>
        <span class="text-accent">]</span>
      </a>
    )
  }
</div>
