---
import type { HTMLAttributes } from 'astro/types';
type Props = HTMLAttributes<'a'> & {
  description?: string;
};
const { href, class: className, description, ...props } = Astro.props;
const pathname = '/' + Astro.url.pathname.replace(import.meta.env.BASE_URL, '').replace(/^\//, '');
const hrefStr = href?.toString() ?? '';
const isActive = hrefStr === pathname || (hrefStr !== '/' && pathname.startsWith(hrefStr));
---

<div class="group/nav flex flex-col gap-0">
  <a
    {href}
    class:list={[
      'font-display block px-4 py-1 tracking-widest lowercase no-underline transition-all duration-200 before:-mr-2',
      { "text-text-primary opacity-100 before:content-['>']": isActive },
      {
        "text-text-secondary/80 hover:text-text-primary opacity-60 before:content-['_'] hover:opacity-100 hover:before:content-['>']":
          !isActive,
      },
      className,
    ]}
    {...props}
  >
    <slot />
  </a>
  {
    description && (
      <p
        class:list={[
          '-mt-1 px-5 font-mono text-[0.6rem] leading-none tracking-widest lowercase transition-colors duration-200',
          isActive
            ? 'text-text-secondary'
            : 'text-text-secondary/30 group-hover/nav:text-text-secondary/60',
        ]}
      >
        <span class="typewriter-text" data-description={description} style="visibility: hidden;">
          {description}
        </span>
      </p>
    )
  }
</div>

<script>
  const initHeaderLinkTypewriters = () => {
    document.querySelectorAll<HTMLElement>('.group\\/nav').forEach((nav) => {
      const link = nav.querySelector('a');
      const typewriterEl = nav.querySelector<HTMLSpanElement>('.typewriter-text');
      if (!link || !typewriterEl || link.dataset.typewriterBound === 'true') return;

      link.dataset.typewriterBound = 'true';

      const description = typewriterEl.dataset.description ?? '';
      const isActive = link.classList.contains('text-text-primary');
      let timeout: ReturnType<typeof setTimeout> | undefined;
      let index = 0;

      if (isActive) {
        typewriterEl.style.visibility = 'visible';
        typewriterEl.textContent = description;
        return;
      }

      link.addEventListener('mouseenter', () => {
        if (timeout) clearTimeout(timeout);
        typewriterEl.textContent = '';
        typewriterEl.style.visibility = 'visible';
        index = 0;

        const type = () => {
          if (index < description.length) {
            typewriterEl.textContent += description[index];
            index++;
            timeout = setTimeout(type, 55);
          }
        };

        type();
      });

      link.addEventListener('mouseleave', () => {
        if (timeout) clearTimeout(timeout);
        typewriterEl.style.visibility = 'hidden';
        typewriterEl.textContent = description;
        index = 0;
      });
    });
  };

  document.addEventListener('astro:page-load', initHeaderLinkTypewriters);
  initHeaderLinkTypewriters();
</script>

<style>
  a::after {
    content: '';
    display: inline-block;
  }
  a:hover::after,
  a.active::after {
    content: '_';
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>
