---
import type { HTMLAttributes } from "astro/types";
type Props = HTMLAttributes<"a">;
const { href, class: className, ...props } = Astro.props;
const pathname = "/" + Astro.url.pathname.replace(import.meta.env.BASE_URL, "").replace(/^\//, "");
const hrefStr = href?.toString() ?? "";
const isActive = hrefStr === pathname || (hrefStr !== "/" && pathname.startsWith(hrefStr));
---
<a

  href={href}
  class:list={[
    "block lowercase px-4 py-1 no-underline transition-all duration-200 font-display tracking-widest before:-mr-2",
    { "before:content-['>'] text-(--text-primary) opacity-100": isActive },
    { "before:content-['_'] text-(--text-secondary) opacity-40 hover:opacity-100 hover:before:content-['>']": !isActive },
    className,
  ]}
  {...props}
>
  <slot />
</a>

<style>
  a::after {
    content: "";
    display: inline-block;
  }

  a:hover::after,
  a.active::after {
    content: "_";
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
