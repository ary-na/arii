---
import { Image } from 'astro:assets';
import SiteLayout from '@layouts/SiteLayout.astro';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '@components/FormattedDate.astro';
import PaginationNav from './PaginationNav.astro';

type Post = CollectionEntry<'blog'>;

interface Props {
  archiveLabel: string;
  archiveTitle: string;
  countLabel: string;
  countNumber?: number;
  description: string;
  canonicalPath?: string;
  currentPage?: number;
  hrefForPage?: (page: number) => string;
  title: string;
  totalPages?: number;
  posts: Post[];
}

const {
  archiveLabel,
  archiveTitle,
  canonicalPath,
  countLabel,
  countNumber,
  currentPage = 1,
  description,
  hrefForPage,
  title,
  totalPages = 1,
  posts,
} = Astro.props;
---

<SiteLayout {title} {description} {canonicalPath}>
  <section class="space-y-6 page-container py-12">
    <div>
    <span class="font-mono text-xs tracking-widest text-(--text-secondary)">
        {countLabel}
        {countNumber !== undefined && <span class="text-highlight">[{countNumber}]</span>}
      </span>

      <h1 class="flex text-3xl items-center gap-2 after:h-px after:flex-1">
         {archiveLabel}
      </h1>

    <span class="font-mono tracking-widest text-secondary text-sm">
      {archiveTitle}
    </span>
    </div>

    <ul class="flex flex-col gap-4">
      {
        posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}/`}
              class="group flex gap-4 rounded border border-dashed border-secondary p-4 no-underline transition-all duration-200 hover:bg-(--bg-secondary) hover:pl-5"
            >
              {/* Cursor */}
              <div class="font-mono text-xs pt-1 shrink-0">
                <span class="hidden animate-blink-slow text-highlight group-hover:inline">
                  ▌
                </span>
                <span class="inline text-(--border-primary) group-hover:hidden">
                  >
                </span>
              </div>

              {/* Title + Description + Meta */}
              <div class="flex min-w-0 flex-1 flex-col gap-1">
                {post.data.category && (
                  <span class="font-mono text-[10px] text-highlight opacity-60">
                    {post.data.category}
                  </span>
                )}
                <p class="truncate font-mono text-sm transition-colors group-hover:text-highlight">
                  {post.data.title}
                </p>
                {post.data.description && (
                  <p class="font-mono text-xs text-(--text-tertiary) line-clamp-2">
                    {post.data.description}
                  </p>
                )}
                <span class="mt-1 font-mono text-[11px] text-(--text-tertiary)">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </div>

              {/* Image */}
              {post.data.heroImage && (
                <div class="shrink-0">
                  <Image
                    width={320}
                    height={200}
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? ''}
                    class="rounded object-cover"
                    style="width: 160px; height: 100px;"
                  />
                </div>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    {
      hrefForPage && (
        <PaginationNav
          currentPage={currentPage}
          totalPages={totalPages}
          hrefForPage={hrefForPage}
        />
      )
    }
  </section>
</SiteLayout>
