---
import { Image } from 'astro:assets';
import SiteLayout from '@layouts/SiteLayout.astro';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '@components/FormattedDate.astro';
import PaginationNav from './PaginationNav.astro';

type Post = CollectionEntry<'blog'>;

interface Props {
  archiveLabel: string;
  archiveTitle: string;
  countLabel: string;
  description: string;
  canonicalPath?: string;
  currentPage?: number;
  hrefForPage?: (page: number) => string;
  title: string;
  totalPages?: number;
  posts: Post[];
}

const {
  archiveLabel,
  archiveTitle,
  canonicalPath,
  countLabel,
  currentPage = 1,
  description,
  hrefForPage,
  title,
  totalPages = 1,
  posts,
} = Astro.props;
---

<SiteLayout {title} {description} {canonicalPath}>
  <section class="mb-16 space-y-4">
    <p class="font-display text-2xl tracking-wide">
      {archiveLabel}
    </p>
    <h1 class="text-4xl">{archiveTitle}</h1>
    <p class="text-(--text-secondary) text-sm">{countLabel}</p>

    <ul class="flex flex-col">
      {
        posts.map((post) => (
          <li class="border-b border-(--border-secondary) last:border-b-0">
            <a href={`/blog/${post.id}/`} class="group flex items-center gap-4 py-4 no-underline">
              {post.data.heroImage && (
                <div class="shrink-0">
                  <Image
                    width={160}
                    height={100}
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? ''}
                    class="rounded object-cover opacity-60 transition-opacity duration-200 group-hover:opacity-100"
                    style="width: 80px; height: 50px;"
                  />
                </div>
              )}
              <div class="flex min-w-0 flex-1 justify-between gap-4">
                <div class="flex min-w-0 flex-col gap-1">
                  <span class="truncate font-mono text-sm text-(--text-secondary) lowercase transition-colors duration-200 group-hover:text-(--accent)">
                    <span class="mr-1">{'>'}</span>
                    {post.data.title}
                  </span>
                  {post.data.description && (
                    <span class="truncate text-xs text-(--text-secondary) opacity-70">
                      {post.data.description}
                    </span>
                  )}
                </div>
                <span class="shrink-0 self-start pt-0.5 font-mono text-xs text-(--text-secondary)">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    {hrefForPage && <PaginationNav currentPage={currentPage} totalPages={totalPages} hrefForPage={hrefForPage} />}
  </section>
</SiteLayout>
