<!-- src/components/ImageViewer.astro -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm"
  style="opacity: 0; pointer-events: none;"
>
  <!-- Close button -->
  <button
    id="lightbox-close"
    aria-label="Close lightbox"
    class="bg-surface-primary/85 border-text-secondary/20 text-text-primary hover:bg-surface-primary absolute top-4 right-4 flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border shadow-(--box-shadow) backdrop-blur-md transition"
  >
    <span
      class="lightbox-line absolute block h-0.5 w-5 rounded-full bg-current"
      style="transform: rotate(45deg)"></span>
    <span
      class="lightbox-line absolute block h-0.5 w-5 rounded-full bg-current"
      style="transform: rotate(-45deg)"></span>
  </button>

  <!-- Prev -->
  <button
    id="lightbox-prev"
    aria-label="Previous image"
    class="bg-surface-primary/85 border-text-secondary/20 text-text-primary hover:bg-surface-primary absolute left-4 flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border shadow-(--box-shadow) backdrop-blur-md transition"
  >
    <span class="font-mono text-sm">&lt;</span>
  </button>

  <!-- Next -->
  <button
    id="lightbox-next"
    aria-label="Next image"
    class="bg-surface-primary/85 border-text-secondary/20 text-text-primary hover:bg-surface-primary absolute right-4 flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border shadow-(--box-shadow) backdrop-blur-md transition"
  >
    <span class="font-mono text-sm">&gt;</span>
  </button>

  <div class="flex flex-col items-center gap-3">
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[85vh] max-w-[90vw] rounded-md"
    />
    <figcaption id="lightbox-caption" class="font-mono text-xs text-white/50">
    </figcaption>
  </div>
</div>

<style>
  .lightbox-line {
    left: 50%;
    top: 50%;
    translate: -50% -50%;
  }

  #lightbox {
    touch-action: manipulation;
  }
</style>

<script is:inline>
  let tries = 0;

  function initLightbox() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');

    if (
      !lightbox ||
      !lightboxImg ||
      !lightboxCaption ||
      !closeBtn ||
      !prevBtn ||
      !nextBtn
    ) {
      return;
    }

    const imgs = document.querySelectorAll('article figure img');

    // retry safely (max 10 attempts)
    if (imgs.length === 0) {
      if (tries < 10) {
        tries++;
        setTimeout(initLightbox, 100);
      }
      return;
    }

    const images = [];
    let currentIndex = 0;

    const show = (index) => {
      if (!images.length) return;

      currentIndex = (index + images.length) % images.length;
      const img = images[currentIndex];

      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightboxCaption.textContent = img.caption;

      prevBtn.style.display = images.length <= 1 ? 'none' : '';
      nextBtn.style.display = images.length <= 1 ? 'none' : '';
    };

    const open = (index) => {
      show(index);

      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');

      lightbox.style.opacity = '1';
      lightbox.style.pointerEvents = 'auto';

      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');

      lightbox.style.opacity = '0';
      lightbox.style.pointerEvents = 'none';

      document.body.style.overflow = '';
    };

    imgs.forEach((img, i) => {
      if (img.dataset.lightboxBound === 'true') return;
      img.dataset.lightboxBound = 'true';

      const figure = img.closest('figure');
      const caption =
        figure?.querySelector('figcaption')?.textContent ?? img.alt ?? '';

      images.push({
        src: img.getAttribute('src') ?? '',
        alt: img.alt ?? '',
        caption,
      });

      img.classList.add('cursor-zoom-in');
      img.onclick = () => open(i);
    });

    closeBtn.onclick = close;
    prevBtn.onclick = () => show(currentIndex - 1);
    nextBtn.onclick = () => show(currentIndex + 1);

    // prevent duplicate lightbox click binding
    if (!lightbox.dataset.bound) {
      lightbox.dataset.bound = 'true';

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) close();
      });
    }

    // prevent duplicate keyboard binding
    if (!window.__lightboxKeyBound) {
      window.__lightboxKeyBound = true;

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') show(currentIndex - 1);
        if (e.key === 'ArrowRight') show(currentIndex + 1);
      });
    }
  }

  // Astro navigation-safe init
  document.addEventListener('astro:page-load', initLightbox);

  // initial load
  initLightbox();
</script>
