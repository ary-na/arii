---
interface Props {
  currentPage: number;
  totalPages: number;
  hrefForPage: (page: number) => string;
}

const { currentPage, totalPages, hrefForPage } = Astro.props;

if (totalPages <= 1) {
  return null;
}

const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<nav
  class="mt-10 flex flex-wrap items-center justify-center gap-2 font-mono text-sm"
  aria-label="Pagination"
>
  {
    currentPage > 1 ? (
      <a
        href={hrefForPage(currentPage - 1)}
        class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-secondary text-(--text-secondary) no-underline transition-all duration-200 hover:border-highlight hover:text-highlight"
        aria-label="Previous page"
      >
        <span class="text-xs">&lt;</span>
      </a>
    ) : (
      <span class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-secondary text-(--text-secondary) opacity-30">
        <span class="text-xs">&lt;</span>
      </span>
    )
  }

  <div class="flex flex-wrap items-center gap-2">
    {
      pages.map((page) => {
        const isCurrent = page === currentPage;
        return isCurrent ? (
          <span class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-highlight bg-highlight/10 text-xs text-highlight">
            {page}
          </span>
        ) : (
<a
            href={hrefForPage(page)}
            class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-secondary text-xs text-(--text-secondary) no-underline transition-all duration-200 hover:border-highlight hover:text-highlight"
          >
            {page}
          </a>
        );
      })
    }
  </div>

  {
    currentPage < totalPages ? (
<a
        href={hrefForPage(currentPage + 1)}
        class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-secondary text-(--text-secondary) no-underline transition-all duration-200 hover:border-highlight hover:text-highlight"
        aria-label="Next page"
      >
        <span class="text-xs">&gt;</span>
      </a>
    ) : (
      <span class="flex h-9 w-9 items-center justify-center rounded border border-dashed border-secondary text-(--text-secondary) opacity-30">
        <span class="text-xs">&gt;</span>
      </span>
    )
  }
</nav>
