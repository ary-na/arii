---
interface Props {
  currentPage: number;
  totalPages: number;
  hrefForPage: (page: number) => string;
}

const { currentPage, totalPages, hrefForPage } = Astro.props;

if (totalPages <= 1) {
  return null;
}

const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<nav
  class="mt-10 flex flex-wrap items-center justify-center gap-2 font-mono text-sm"
  aria-label="Pagination"
>
  {
    currentPage > 1 ? (
      <a
        href={hrefForPage(currentPage - 1)}
        class="bg-surface-primary/85 border-text-secondary/20 text-text-primary hover:bg-surface-primary flex h-11 w-11 items-center justify-center rounded-full border no-underline shadow-(--box-shadow) backdrop-blur-md transition"
        aria-label="Previous page"
      >
        <span class="text-sm">&lt;</span>
      </a>
    ) : (
      <span class="bg-surface-primary/85 border-text-secondary/20 text-text-secondary flex h-11 w-11 items-center justify-center rounded-full border opacity-30 shadow-(--box-shadow)">
        <span class="text-sm">&lt;</span>
      </span>
    )
  }

  <div class="flex flex-wrap items-center gap-2">
    {
      pages.map((page) => {
        const isCurrent = page === currentPage;
        return isCurrent ? (
          <span class="bg-surface-primary border-text-primary text-text-primary flex h-11 w-11 items-center justify-center rounded-full border shadow-(--box-shadow)">
            {page}
          </span>
        ) : (
          <a
            href={hrefForPage(page)}
            class="bg-surface-primary/85 border-text-secondary/20 text-text-secondary hover:bg-surface-primary hover:text-text-primary flex h-11 w-11 items-center justify-center rounded-full border no-underline shadow-(--box-shadow) backdrop-blur-md transition"
          >
            {page}
          </a>
        );
      })
    }
  </div>

  {
    currentPage < totalPages ? (
      <a
        href={hrefForPage(currentPage + 1)}
        class="bg-surface-primary/85 border-text-secondary/20 text-text-primary hover:bg-surface-primary flex h-11 w-11 items-center justify-center rounded-full border no-underline shadow-(--box-shadow) backdrop-blur-md transition"
        aria-label="Next page"
      >
        <span class="text-sm">&gt;</span>
      </a>
    ) : (
      <span class="bg-surface-primary/85 border-text-secondary/20 text-text-secondary flex h-11 w-11 items-center justify-center rounded-full border opacity-30 shadow-(--box-shadow)">
        <span class="text-sm">&gt;</span>
      </span>
    )
  }
</nav>
