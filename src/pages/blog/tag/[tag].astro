---
import { getCollection } from 'astro:content';
import { BLOG_PAGE_SIZE, tagPageHref } from '@/consts';
import BlogArchive from '@components/BlogArchive.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))];

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const description = `Posts filed under ${tag}`;
const posts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const paginatedPosts = posts.slice(0, BLOG_PAGE_SIZE);
const totalPages = Math.ceil(posts.length / BLOG_PAGE_SIZE);
const countLabel = 'posts with this tag';
const countNumber = posts.length;
---

<BlogArchive
  archiveLabel="Tag archive"
  archiveTitle={`#${tag}`}
  countLabel={countLabel}
  countNumber={countNumber}
  currentPage={1}
  description={description}
  hrefForPage={(page) => tagPageHref(tag, page)}
  posts={paginatedPosts}
  title={`${tag} | Tags`}
  totalPages={totalPages}
/>
