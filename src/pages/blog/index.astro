---
import { type CollectionEntry, getCollection } from 'astro:content'
import BlogArchive from '@components/BlogArchive.astro'
import {
  BLOG_PAGE_SIZE,
  SITE_DESCRIPTION,
  SITE_TITLE,
  blogPageHref,
} from '@/consts'

type BlogPostEntry = CollectionEntry<'blog'>

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)

const posts = allPosts.slice(0, BLOG_PAGE_SIZE)
const totalPages = Math.ceil(allPosts.length / BLOG_PAGE_SIZE)
const countLabel = 'all posts'
const countNumber = allPosts.length
---

<BlogArchive
  archiveLabel="all posts"
  archiveTitle=""
  countLabel={countLabel}
  countNumber={countNumber}
  currentPage={1}
  description={SITE_DESCRIPTION}
  hrefForPage={blogPageHref}
  posts={posts as BlogPostEntry[]}
  title={SITE_TITLE}
  totalPages={totalPages}
/>
