---
import type { GetStaticPaths } from 'astro'
import { type CollectionEntry, getCollection } from 'astro:content'
import BlogArchive from '@components/BlogArchive.astro'
import {
  BLOG_PAGE_SIZE,
  blogPageHref,
  SITE_DESCRIPTION,
  SITE_TITLE,
} from '@/consts'

type BlogPostEntry = CollectionEntry<'blog'>

interface PaginatedPage<T> {
  currentPage: number
  data: T[]
  lastPage: number
  total: number
}

interface Props {
  page: PaginatedPage<BlogPostEntry>
}

type GetStaticPathsContext = Parameters<GetStaticPaths>[0]

export const getStaticPaths: GetStaticPaths = async ({
  paginate,
}: GetStaticPathsContext) => {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  )
  return paginate(posts, { pageSize: BLOG_PAGE_SIZE })
}

const { page } = Astro.props as Props
const canonicalPath = blogPageHref(page.currentPage)
const countLabel = 'all posts'
---

<BlogArchive
  archiveLabel="all posts"
  archiveTitle=""
  countLabel={countLabel}
  countNumber={page.total}
  currentPage={page.currentPage}
  description={SITE_DESCRIPTION}
  canonicalPath={canonicalPath}
  hrefForPage={blogPageHref}
  posts={page.data as BlogPostEntry[]}
  title={`${SITE_TITLE} | Blog | Page ${page.currentPage}`}
  totalPages={page.lastPage}
/>
