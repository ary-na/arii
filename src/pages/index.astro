---
import SiteLayout from "@layouts/SiteLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const latest = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 9);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  {/* Hero section */}
  <section class="page-container space-y-6 pt-15">
   <span class="font-mono text-xs tracking-widest text-(--text-secondary)">
  developer . melbourne
  <span class="align-middle">🇦🇺</span><img
    src="https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f1ee-1f1f7.svg"
    alt="Iranian imperial flag"
    class="inline-block align-middle"
    style="width: 1.2em; height: 1.2em;"
  /> . ai systems
</span>

    <h1 class="text-5xl font-bold">
      <span data-typewriter="hi, i'm arian"></span>
      <span class="animate-blink">_</span>
    </h1>

    <p class="text-lg">
      I write about what I'm learning, what I'm building, and the systems I
      work with.
    </p>

    <p class="text-sm italic text-(--text-secondary)">
      Mostly AI/ML, Swift, and whatever rabbit hole I fell into this week.
    </p>

<div class="flex flex-col gap-4 text-xs font-mono">
  <div class="flex items-center gap-2">
    <span class="text-secondary">></span>
    <a href="/about" class="hover:text-secondary">about me</a>
  </div>
  <div class="flex items-center gap-2">
    <span class="text-secondary">></span>
    <a href="/blog" class="hover:text-secondary">read the blog</a>
  </div>
</div>
  </section>

  {/* Latest posts section */}
  <section class="page-container py-15 space-y-6">
    <span class="font-mono text-xs tracking-widest text-(--text-secondary)">
      things I'm building and figuring out
    </span>

    <h2 class="mb-4 flex text-3xl items-center gap-2 after:h-px after:flex-1">
      latest posts
      <span class="text-highlight">[{posts.length}]</span>
    </h2>

    <ul
      class="divide-y divide-dashed divide-secondary border border-dashed border-secondary rounded"
    >
      {
        latest.map((post) => (
          <li>
            <a
              href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
              class="group grid grid-cols-[14px_1fr_auto] items-stretch gap-2 px-4 py-4 no-underline transition-all duration-200 hover:bg-(--bg-secondary) hover:pl-5"
            >
              {/* Cursor */}
              <div class="font-mono text-xs pt-1">
                <span class="hidden animate-blink-slow text-highlight group-hover:inline">
                  ▌
                </span>
                <span class="inline text-(--border-primary) group-hover:hidden">
                  >
                </span>
              </div>

              {/* Title + Description */}
              <div class="flex min-w-0 flex-col gap-2">
                {post.data.category && (
                  <span class="font-mono text-[10px] text-highlight opacity-60">
                    {post.data.category}
                  </span>
                )}
                <p class="truncate font-mono text-sm transition-colors group-hover:text-highlight">
                  {post.data.title}
                </p>
                {post.data.description && (
                  <p class="truncate font-mono text-xs text-(--text-tertiary)">
                    {post.data.description}
                  </p>
                )}
              </div>

              {/* Date */}
              <div class="flex flex-col items-end text-right justify-start">
                <span class="font-mono text-[11px] text-(--text-tertiary)">
                  {post.data.pubDate.toLocaleDateString("en-AU", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  {/* More section */}
    <section class="dark:bg-black bg-violet-100 py-15">
    <div class="page-container space-y-6">
    <span class="font-mono text-xs tracking-widest text-(--text-secondary)">
      keep exploring
    </span>

    <h2 class="mb-4 flex text-3xl items-center gap-2 after:h-px after:flex-1">
      more
    </h2>

<div class="grid grid-cols-2 gap-2">
  <a
    href="/blog"
    class="group grid grid-cols-[14px_1fr] items-stretch gap-2 rounded border border-dashed border-secondary px-4 py-4 no-underline transition-all duration-200 hover:bg-(--bg-secondary) hover:pl-5"
  >
    <div class="font-mono text-xs pt-1">
      <span class="hidden animate-blink-slow text-highlight group-hover:inline">▌</span>
      <span class="inline text-(--border-primary) group-hover:hidden">></span>
    </div>
    <div class="flex min-w-0 flex-col gap-2">
      <p class="font-mono text-xs text-(--text-primary) group-hover:text-highlight">all posts</p>
      <p class="font-mono text-[10px] text-(--text-tertiary)">read everything</p>
    </div>
  </a>
  <a
    href="/blog/category/project"
    class="group grid grid-cols-[14px_1fr] items-stretch gap-2 rounded border border-dashed border-secondary px-4 py-4 no-underline transition-all duration-200 hover:bg-(--bg-secondary) hover:pl-5"
  >
    <div class="font-mono text-xs pt-1">
      <span class="hidden animate-blink-slow text-highlight group-hover:inline">▌</span>
      <span class="inline text-(--border-primary) group-hover:hidden">></span>
    </div>
    <div class="flex min-w-0 flex-col gap-2">
      <p class="font-mono text-xs text-(--text-primary) group-hover:text-highlight">projects</p>
      <p class="font-mono text-[10px] text-(--text-tertiary)">see what i built</p>
    </div>
  </a>
</div>
</div>
  </section>

  {/* Find me section */}
  <section class="page-container py-15">
      <span class="font-mono text-xs tracking-widest text-(--text-secondary)">
        elsewhere on the web
      </span>

      <h2 class="mb-4 flex text-3xl items-center gap-2 after:h-px after:flex-1">
        find me
      </h2>

<div class="flex flex-col gap-4 text-xs font-mono">
  <div class="flex items-center gap-2">
    <span class="text-secondary">></span>
    <a href="https://x.com/ariiparsa" class="hover:text-secondary">https://x.com/ariiparsa</a>
  </div>
  <div class="flex items-center gap-2">
    <span class="text-secondary">></span>
    <a href="https://github.com/ary-na" class="hover:text-secondary">https://github.com/ary-na</a>
  </div>
  <div class="flex items-center gap-2">
    <span class="text-secondary">></span>
    <a href="https://linkedin.com/in/arian-najafi-yamchelo" class="hover:text-secondary">https://linkedin.com/in/arian-najafi-yamchelo</a>
  </div>
</div>
  </section>
</SiteLayout>

<script>
  import { initTypewriter } from "@/scripts/typewriter";

  document.addEventListener("astro:page-load", () => {
    initTypewriter();
  });

  initTypewriter();
</script>
