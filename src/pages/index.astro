---
import SiteLayout from "@layouts/SiteLayout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const latest = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

<!-- Intro -->
<section class="mb-16 space-y-4">
  <span class="text-xs text-(--text-secondary) font-mono tracking-widest">developer / melbourne / ai</span>
  <h1 class="text-4xl"><span id="typewriter"></span><span class="cursor">_</span></h1>
  <p class="text-lg">I make things with code. Some of them even work.</p>
  <p class="text-sm text-(--text-secondary) italic">This is where I write about what I'm learning, what I'm building, and the tools and systems I work with.</p>
  <a href="/about" class="block font-mono text-sm hover:text-(--accent) transition-colors duration-200">
    <span class="text-(--text-secondary)">></span> read more about me
  </a>
</section>

<!-- Latest Posts -->
<section class="mb-16 space-y-4">
    <h2 class="font-display tracking-wide text-2xl">
      latest posts [{posts.length}]
    </h2>
     <ul class="flex flex-col text-sm">
      {latest.map((post) => (
        <li class="border-b border-(--border-secondary) last:border-b-0">
          <a
            href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
            class="group flex items-start justify-between gap-4 py-4 no-underline"
          >
            <div class="flex flex-col gap-1 min-w-0">
              <span class="font-mono lowercase text-(--text-secondary) group-hover:text-(--accent) transition-colors duration-200">
                <span class="mr-1">> </span>
                {post.data.title}
              </span>
              {post.data.description && (
                <span class="text-xs text-(--text-secondary) opacity-60 truncate">
                  {post.data.description}
                </span>
              )}
            </div>
            <span class="text-xs font-mono text-(--text-secondary) shrink-0 pt-0.5">
              {post.data.pubDate.toLocaleDateString("en-AU", { year: "numeric", month: "short", day: "numeric" })}
            </span>
          </a>
        </li>
      ))}
    </ul>
</section>

<!-- Contact -->
<section class="mb-8 md:mb-16 font-mono text-sm space-y-4">
    <h2 class="font-display tracking-wide text-2xl">
     find me
    </h2>
  <div class="space-y-1 border p-5 border-secondary rounded">
    <a href="https://twitter.com/ariiparsa" class="group flex items-center gap-2 no-underline">
      <span class="text-(--accent)">arii@dev:~$</span>
      <span class="group-hover:text-(--accent) transition-colors duration-200">open x</span>
    </a>
    <a href="https://github.com/ary-na" class="group flex items-center gap-2 no-underline">
      <span class="text-(--accent)">arii@dev:~$</span>
      <span class="group-hover:text-(--accent) transition-colors duration-200">open github</span>
    </a>
    <p class="text-(--accent)">arii@dev:~$ <span class="cursor">_</span></p>
  </div>
</section>

</SiteLayout>

<style>
  .cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>

<script>
  const text = "hi, i'm arian.";
  let timeout: ReturnType<typeof setTimeout> | undefined;

  const initTypewriter = () => {
    const el = document.getElementById('typewriter') as HTMLElement | null;
    if (!el) return;

    if (timeout) {
      clearTimeout(timeout);
    }

    el.textContent = '';
    let index = 0;

    const type = () => {
      if (index >= text.length) return;

      el.textContent += text[index];
      index += 1;
      timeout = setTimeout(type, 80);
    };

    type();
  };

  document.addEventListener('astro:page-load', initTypewriter);
  initTypewriter();
</script>
